# ==========================================
# VARIABLES DE ENTORNO DEL SERVIDOR
# ==========================================

# El puerto donde escucha el servidor.
# - En Local: Mantené 8080 (o el que prefieras).
# - En Global/Producción: Tu proveedor de hosting (Render, AWS, etc) inyectará este puerto automáticamente.
PORT=8080

# Entorno de ejecución (development o production)
NODE_ENV=development
